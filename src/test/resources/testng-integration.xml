<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Integration test suite — runs browser-based tests in headless mode.
  Intended for CI/CD pipelines where a display is not available.
  Pass -Dheadless=true -Dbrowser=chrome when running this suite.

  Satisfies Requirements: 2.5, 3.1, 3.2, 9.1, 9.3
-->
<suite name="Selenium Test Framework — Integration Tests"
       parallel="methods"
       thread-count="4"
       verbose="1">

    <!-- Register AllureListener for all tests in this suite -->
    <listeners>
        <listener class-name="core.report.AllureListener"/>
    </listeners>

    <test name="Integration Tests">
        <parameter name="browser" value="chrome"/>
        <parameter name="headless" value="true"/>
        <packages>
            <package name="tests"/>
        </packages>
    </test>

</suite>
