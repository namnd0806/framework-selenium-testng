<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Unit and property test suite.
  Runs unit tests and jqwik property tests in parallel.
  thread-count is hardcoded to 4 (XML is parsed before Maven system properties
  are available to the XML parser).

  Satisfies Requirements: 3.1, 3.2, 3.4, 3.6
-->
<suite name="Selenium Test Framework — Unit &amp; Property Tests"
       parallel="methods"
       thread-count="4"
       verbose="1">

    <!-- Register AllureListener for all tests in this suite -->
    <listeners>
        <listener class-name="core.report.AllureListener"/>
    </listeners>

    <test name="Unit and Property Tests">
        <packages>
            <package name="core.config"/>
            <package name="core.driver"/>
            <package name="core.utils"/>
            <package name="core.report"/>
            <package name="base"/>
            <package name="dataproviders"/>
        </packages>
    </test>

</suite>
